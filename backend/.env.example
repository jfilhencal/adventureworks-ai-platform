# Copy this file to .env and fill in real values. Never commit the real .env file.

# SQL Server Connection
# SQL_AUTH_MODE options: windows | sql | azure_ad_default | azure_ad_interactive | azure_ad_managed_identity
# --- Local dev (LocalDB, Windows Authentication) ---
# SQL_SERVER=(localdb)\\MSSQLLocalDB
# SQL_DATABASE=AdventureWorksDW2022
# SQL_AUTH_MODE=windows

# --- Azure SQL ---
SQL_SERVER=
SQL_DATABASE=
SQL_AUTH_MODE=azure_ad_interactive
SQL_DRIVER=ODBC Driver 18 for SQL Server
SQL_USER=
SQL_PASSWORD=
SQL_MANAGED_IDENTITY_CLIENT_ID=
AZURE_TENANT_ID=

# Azure AI Foundry / Azure OpenAI (managed identity based, no API keys)
# AZURE_OPENAI_AUTH_MODE options: default (managed identity, prod) | interactive (browser login, local dev)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_AUTH_MODE=default
AZURE_OPENAI_MANAGED_IDENTITY_CLIENT_ID=

# Azure Storage (blob-based exports/artifacts)
AZURE_STORAGE_ACCOUNT_URL=
AZURE_STORAGE_CONTAINER=forecast-exports
